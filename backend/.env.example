# Anthropic Claude API
ANTHROPIC_API_KEY=your_claude_api_key_here

# Facebook & Instagram (Business)
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:your_person_id
LINKEDIN_ORG_URN=urn:li:organization:your_org_id

# Gmail
GMAIL_CREDENTIALS_PATH=gmail_credentials.json
GMAIL_TOKEN_PATH=gmail_token.pickle
GMAIL_FROM_EMAIL=your_gmail@gmail.com

# Instagram Direct (Alternative to Facebook Graph API)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Database
DATABASE_URL=sqlite:///./social_posts.db

# Upload Settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880
